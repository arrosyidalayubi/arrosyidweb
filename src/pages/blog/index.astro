---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// 1. Ambil semua data dari collection 'blog'
const allPosts = await getCollection('blog');

// 2. Urutkan artikel dari tanggal terbaru ke terlama
const sortedPosts = allPosts.sort((a, b) => {
  return new Date(b.data.publishDate).valueOf() - new Date(a.data.publishDate).valueOf();
});
---

<BaseLayout title="Blog Pribadi" description="Kumpulan artikel, tutorial web development, dan catatan pribadi saya.">
  <div class="max-w-4xl mx-auto px-4 py-16">
    
    <!-- Header Halaman -->
    <header class="mb-12">
      <h1 class="text-4xl font-extrabold text-slate-900 tracking-tight mb-4">Tulisan Terbaru</h1>
      <p class="text-lg text-slate-600">
        Eksplorasi teknis, catatan belajar, dan dokumentasi perjalanan saya di dunia web development.
      </p>
    </header>

    <!-- Grid Daftar Artikel -->
    <div class="grid gap-8 md:grid-cols-2">
      {sortedPosts.map((post) => (
        <article class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 hover:shadow-lg hover:border-slate-300 transition-all duration-300 group flex flex-col justify-between">
          <div>
            <a href={`/blog/${post.id}`} class="block">
              <h2 class="text-2xl font-bold text-slate-800 mb-3 group-hover:text-blue-600 transition-colors">
                {post.data.title}
              </h2>
              <p class="text-slate-600 mb-4 line-clamp-3">
                {post.data.description}
              </p>
            </a>
          </div>
          
          <div class="mt-4 pt-4 border-t border-slate-100 flex flex-col sm:flex-row sm:items-center justify-between gap-3">
            <!-- Format Tanggal (Misal: 9 Mei 2026) -->
            <time datetime={post.data.publishDate.toISOString()} class="text-sm font-medium text-slate-500">
              {new Date(post.data.publishDate).toLocaleDateString('id-ID', {
                year: 'numeric',
                month: 'long',
                day: 'numeric'
              })}
            </time>
            
            <!-- Looping Tags (Jika ada) -->
            {post.data.tags && (
              <div class="flex gap-2 flex-wrap">
                {post.data.tags.slice(0, 2).map((tag: string) => (
                  <span class="px-2.5 py-1 bg-slate-100 text-slate-600 text-xs font-semibold rounded-full">
                    #{tag}
                  </span>
                ))}
              </div>
            )}
          </div>
        </article>
      ))}
    </div>

  </div>
</BaseLayout>
---
// src/pages/blog/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const allPosts = await getCollection('blog');

const sortedPosts = allPosts.sort((a, b) => {
  return new Date(b.data.publishDate).valueOf() - new Date(a.data.publishDate).valueOf();
});
---

<BaseLayout title="Artikel & Tulisan" description="Kumpulan artikel, tutorial web development, dan catatan pribadi saya.">
  <div class="max-w-4xl mx-auto px-4 py-16 md:py-24">
    
    <!-- Header Halaman Minimalis -->
    <header class="mb-16 border-b border-slate-200 dark:border-slate-800 pb-8">
      <h1 class="text-4xl md:text-5xl font-extrabold text-slate-900 dark:text-white tracking-tight mb-4">Artikel</h1>
      <p class="text-lg text-slate-600 dark:text-slate-400">
        Eksplorasi teknis dan dokumentasi perjalanan saya di dunia web development.
      </p>
    </header>

    <!-- Daftar Artikel (List View) -->
    <div class="space-y-12 md:space-y-16">
      {sortedPosts.map((post) => (
        <article class="group flex flex-col md:flex-row gap-6 md:gap-10 items-start">
          
          <!-- Bagian Thumbnail (Kiri pada Desktop, Atas pada Mobile) -->
          <a href={`/blog/${post.id}`} class="block relative w-full md:w-72 h-48 md:h-44 shrink-0 overflow-hidden rounded-2xl bg-slate-100 dark:bg-slate-800">
            {post.data.coverImage ? (
              <Image 
                src={post.data.coverImage} 
                alt={`Cover ${post.data.title}`} 
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out"
                width={600}
                height={400}
              />
            ) : (
              <div class="absolute inset-0 flex items-center justify-center text-slate-300 dark:text-slate-600">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>
              </div>
            )}
          </a>

          <!-- Bagian Teks (Kanan pada Desktop, Bawah pada Mobile) -->
          <div class="flex-1 flex flex-col justify-center">
            
            <!-- Metadata: Tanggal & Tag -->
            <div class="flex flex-wrap items-center gap-3 mb-3 text-sm">
              <time datetime={post.data.publishDate.toISOString()} class="font-medium text-slate-500 dark:text-slate-400">
                {new Date(post.data.publishDate).toLocaleDateString('id-ID', {
                  year: 'numeric', month: 'long', day: 'numeric'
                })}
              </time>
              
              {post.data.tags && (
                <>
                  <span class="text-slate-300 dark:text-slate-600 hidden sm:inline">•</span>
                  <div class="flex gap-2">
                    {post.data.tags.slice(0, 2).map((tag: string) => (
                      <span class="font-semibold text-blue-600 dark:text-blue-400">#{tag}</span>
                    ))}
                  </div>
                </>
              )}
            </div>

            <!-- Judul & Deskripsi -->
            <a href={`/blog/${post.id}`} class="block">
              <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-3 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors leading-snug">
                {post.data.title}
              </h2>
              <p class="text-slate-600 dark:text-slate-400 leading-relaxed line-clamp-2 md:line-clamp-3 mb-4">
                {post.data.description}
              </p>
            </a>

            <!-- Tombol Aksi (Baca Selengkapnya) -->
            <div>
              <a href={`/blog/${post.id}`} class="inline-flex items-center text-sm font-bold text-blue-600 dark:text-blue-400 group-hover:translate-x-1 transition-transform">
                Baca Artikel <span class="ml-1">→</span>
              </a>
            </div>

          </div>
        </article>
      ))}
    </div>

  </div>
</BaseLayout>
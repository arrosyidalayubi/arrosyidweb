---
// src/pages/vlog/[slug].astro
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Comment from '../../components/shared/Comment.astro';

export async function getStaticPaths() {
  const vlogEntries = await getCollection('vlog');
  return vlogEntries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, location, publishDate, gallery } = entry.data;
---

<BaseLayout title={title} description={`Vlog perjalanan di ${location}`}>
  <article class="max-w-5xl mx-auto px-4 py-16 md:py-24">
    
    <header class="text-center mb-12 max-w-3xl mx-auto">
      <div class="flex items-center justify-center gap-2 mb-4 text-blue-600 dark:text-blue-400 font-semibold uppercase tracking-widest text-sm">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
        <span>{location}</span>
      </div>
      <h1 class="text-4xl md:text-6xl font-extrabold text-slate-900 dark:text-white mb-6">{title}</h1>
      <time class="text-slate-500 dark:text-slate-400">
        {new Date(publishDate).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
    </header>

    <!-- Mosaic Gallery -->
    {gallery && gallery.length > 0 && (
      <div class="grid grid-cols-2 md:grid-cols-4 gap-2 md:gap-4 mb-16 breakout px-4 md:px-0">
        {gallery.map((imgUrl, index) => (
          <div class={`overflow-hidden rounded-2xl bg-slate-200 dark:bg-slate-800 ${index === 0 || index === 3 ? 'col-span-2 row-span-2 h-64 md:h-96' : 'col-span-1 h-32 md:h-48'}`}>
            <img 
              src={imgUrl} 
              alt={`Galeri ${index + 1}`} 
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
              loading={index < 2 ? "eager" : "lazy"} 
            />
          </div>
        ))}
      </div>
    )}

    <!-- Teks Cerita Vlog -->
    <div class="prose prose-lg prose-slate dark:prose-invert mx-auto">
      <Content />
    </div>

    <div class="max-w-3xl mx-auto mt-8">
      <Comment />
    </div>

  </article>
</BaseLayout>
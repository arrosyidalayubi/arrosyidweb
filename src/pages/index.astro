---
import BaseLayout from '../layouts/BaseLayout.astro';
// Catatan: Pastikan kamu menambahkan foto profilmu di folder src/assets/images/
// import { Image } from 'astro:assets';
// import profilePic from '../assets/images/profil.jpg';
---

<BaseLayout title="Portofolio | Arrosyid Al Ayubi" description="Web & Mobile Developer. Mahasiswa Sistem Informasi yang berfokus pada performa dan skalabilitas aplikasi.">
  <div class="max-w-5xl mx-auto px-4 md:px-8 py-12 md:py-20">
    
    <!-- Hero Section -->
    <section class="flex flex-col-reverse md:flex-row items-center justify-between gap-12 mb-24">
      <div class="flex-1 space-y-6 text-center md:text-left">
        <div class="inline-block px-4 py-1.5 rounded-full bg-blue-50 text-blue-700 text-sm font-semibold tracking-wide border border-blue-100">
          Tersedia untuk Proyek & Kolaborasi
        </div>
        <h1 class="text-4xl md:text-6xl font-extrabold text-slate-900 leading-tight tracking-tight">
          Halo, saya <span class="text-transparent bg-clip-text bg-linear-to-r from-blue-600 to-indigo-600">Arrosyid Al Ayubi</span>.
        </h1>
        <p class="text-lg md:text-xl text-slate-600 leading-relaxed max-w-2xl">
          Seorang pengembang perangkat lunak dan mahasiswa Sistem Informasi di Universitas Pamulang. Saya memiliki ketertarikan mendalam dalam merancang arsitektur web modern, aplikasi Android, dan infrastruktur server yang tangguh.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 pt-4 justify-center md:justify-start">
          <a href="#proyek" class="px-8 py-3.5 bg-slate-900 text-white font-medium rounded-xl hover:bg-slate-800 transition-colors shadow-lg hover:shadow-xl focus:ring-4 focus:ring-slate-200">
            Lihat Pekerjaan Saya
          </a>
          <a href="/blog" class="px-8 py-3.5 bg-white text-slate-700 font-medium rounded-xl border border-slate-200 hover:border-slate-300 hover:bg-slate-50 transition-colors shadow-sm focus:ring-4 focus:ring-slate-100">
            Baca Tulisan Saya
          </a>
        </div>
      </div>
      
      <!-- Placeholder Foto Profil -->
      <div class="w-48 h-48 md:w-72 md:h-72 relative rounded-full overflow-hidden border-4 border-white shadow-2xl shrink-0 bg-slate-200">
         <!-- Hapus komentar di bawah jika gambar sudah tersedia -->
         <!-- <Image src={profilePic} alt="Arrosyid Al Ayubi" class="w-full h-full object-cover" /> -->
         <div class="absolute inset-0 flex items-center justify-center text-slate-400 font-medium">Foto Profil</div>
      </div>
    </section>

    <!-- Tech Stack / Keterampilan -->
    <section class="mb-24">
      <h2 class="text-2xl font-bold text-slate-900 mb-8 border-b border-slate-200 pb-4">Tech Stack & Keahlian</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          { category: 'Frontend', tech: 'Astro, React, Next.js, Tailwind CSS' },
          { category: 'Backend & DB', tech: 'PHP 8, MySQL, MariaDB, MongoDB' },
          { category: 'Mobile', tech: 'Kotlin, Android Studio' },
          { category: 'Infrastruktur', tech: 'Nginx, Cloudflare Tunnels, Cisco' }
        ].map((item) => (
          <div class="p-5 rounded-2xl bg-white border border-slate-100 shadow-sm hover:shadow-md transition-shadow">
            <h3 class="text-sm font-semibold text-blue-600 mb-2 uppercase tracking-wider">{item.category}</h3>
            <p class="text-slate-700 font-medium">{item.tech}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Featured Projects -->
    <section id="proyek" class="mb-24">
      <h2 class="text-2xl font-bold text-slate-900 mb-8 border-b border-slate-200 pb-4">Proyek Pilihan</h2>
      <div class="grid md:grid-cols-2 gap-8">
        
        <!-- Kartu Proyek 1 -->
        <div class="group bg-white rounded-3xl border border-slate-200 overflow-hidden hover:shadow-2xl transition-all duration-300">
          <div class="h-48 bg-slate-100 flex items-center justify-center border-b border-slate-200 overflow-hidden">
            <span class="text-slate-400 font-medium">Preview Raport Elektronik</span>
          </div>
          <div class="p-8">
            <div class="flex gap-2 mb-4">
              <span class="px-3 py-1 bg-blue-50 text-blue-700 text-xs font-bold rounded-full">PHP</span>
              <span class="px-3 py-1 bg-slate-100 text-slate-700 text-xs font-bold rounded-full">MySQL</span>
            </div>
            <h3 class="text-2xl font-bold text-slate-900 mb-3">Sistem e-Raport Sekolah</h3>
            <p class="text-slate-600 mb-6 leading-relaxed">
              Pengembangan sistem informasi manajemen nilai sekolah lengkap dengan landing page institusi, dirancang untuk memudahkan administrasi akademik secara digital.
            </p>
            <a href="#" class="inline-flex items-center text-blue-600 font-semibold group-hover:text-blue-700">
              Lihat Detail Proyek <span class="ml-2 group-hover:translate-x-1 transition-transform">→</span>
            </a>
          </div>
        </div>

        <!-- Kartu Proyek 2 -->
        <div class="group bg-white rounded-3xl border border-slate-200 overflow-hidden hover:shadow-2xl transition-all duration-300">
          <div class="h-48 bg-slate-100 flex items-center justify-center border-b border-slate-200 overflow-hidden">
            <span class="text-slate-400 font-medium">Preview FitSmart</span>
          </div>
          <div class="p-8">
            <div class="flex gap-2 mb-4">
              <span class="px-3 py-1 bg-blue-50 text-blue-700 text-xs font-bold rounded-full">Kotlin</span>
              <span class="px-3 py-1 bg-slate-100 text-slate-700 text-xs font-bold rounded-full">AI Analysis</span>
            </div>
            <h3 class="text-2xl font-bold text-slate-900 mb-3">FitSmart</h3>
            <p class="text-slate-600 mb-6 leading-relaxed">
              Aplikasi mobile kebugaran yang dilengkapi dengan fitur analisis makanan visual berbasis AI untuk membantu pengguna melacak nutrisi dan profil kesehatan mereka.
            </p>
            <a href="#" class="inline-flex items-center text-blue-600 font-semibold group-hover:text-blue-700">
              Lihat Detail Proyek <span class="ml-2 group-hover:translate-x-1 transition-transform">→</span>
            </a>
          </div>
        </div>

        <!-- Kartu Proyek 3 -->
        <div class="group bg-white rounded-3xl border border-slate-200 overflow-hidden hover:shadow-2xl transition-all duration-300 md:col-span-2 md:flex">
          <div class="h-48 md:h-auto md:w-2/5 bg-slate-100 flex items-center justify-center border-b md:border-b-0 md:border-r border-slate-200 overflow-hidden shrink-0">
             <span class="text-slate-400 font-medium">Preview SaaS Wedding</span>
          </div>
          <div class="p-8 flex-1">
            <div class="flex gap-2 mb-4">
              <span class="px-3 py-1 bg-blue-50 text-blue-700 text-xs font-bold rounded-full">Next.js / Astro</span>
              <span class="px-3 py-1 bg-slate-100 text-slate-700 text-xs font-bold rounded-full">SaaS</span>
            </div>
            <h3 class="text-2xl font-bold text-slate-900 mb-3">Multitenant Wedding Invitation Platform</h3>
            <p class="text-slate-600 mb-6 leading-relaxed">
              Platform Software as a Service (SaaS) untuk pembuatan undangan pernikahan digital. Mendukung arsitektur multitenant dengan fitur integrasi custom domain untuk setiap klien.
            </p>
            <a href="#" class="inline-flex items-center text-blue-600 font-semibold group-hover:text-blue-700">
              Lihat Arsitektur Proyek <span class="ml-2 group-hover:translate-x-1 transition-transform">→</span>
            </a>
          </div>
        </div>

      </div>
    </section>

  </div>
</BaseLayout>
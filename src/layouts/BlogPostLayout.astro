---
// src/layouts/BlogPostLayout.astro
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/blog/TableOfContents.astro';
import ShareButtons from '../components/blog/ShareButtons.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    publishDate: Date;
    tags?: string[];
    coverImage?: ImageMetadata;
  };
  // Tambahkan properti headings untuk menerima data dari [slug].astro
  headings: { depth: number; slug: string; text: string }[];
}

const { frontmatter, headings } = Astro.props;
const currentUrl = Astro.url.href; // Dapatkan URL saat ini secara otomatis
---

<BaseLayout title={frontmatter.title} description={frontmatter.description}>
  <div class="max-w-6xl mx-auto px-4 py-16 md:py-24">
    
    <!-- Header Artikel (Sama seperti sebelumnya) -->
    <header class="mb-12 md:mb-20 text-center max-w-3xl mx-auto">
      <time datetime={frontmatter.publishDate.toISOString()} class="text-sm font-bold text-blue-600 dark:text-blue-400 uppercase tracking-widest mb-4 block">
        {new Date(frontmatter.publishDate).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      <h1 class="text-3xl md:text-5xl font-extrabold text-slate-900 dark:text-white leading-tight mb-6">
        {frontmatter.title}
      </h1>
      <!-- Tags -->
      {frontmatter.tags && (
        <div class="flex flex-wrap justify-center gap-2">
          {frontmatter.tags.map((tag) => (
            <span class="px-3 py-1 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 text-sm font-medium rounded-full">
              #{tag}
            </span>
          ))}
        </div>
      )}
    </header>

    {frontmatter.coverImage && (
      <div class="mb-12 md:mb-16 rounded-3xl overflow-hidden shadow-2xl border border-slate-200 dark:border-slate-800">
        <Image 
          src={frontmatter.coverImage} 
          alt={`Ilustrasi untuk ${frontmatter.title}`} 
          class="w-full h-full hover:scale-105 transition-transform duration-700"
          loading="eager" 
        />
      </div>
    )}

    <!-- GRID LAYOUT: 2 Kolom pada Desktop -->
    <div class="flex flex-col lg:flex-row gap-12 lg:gap-16">
      
      <!-- Kolom Kiri: Konten Utama (Lebar: Fleksibel) -->
      <article class="flex-1 w-full max-w-3xl">
        
        <!-- DAFTAR ISI MOBILE (Hanya muncul di layar kecil) -->
        <div class="block lg:hidden mb-10 p-6 bg-slate-50 dark:bg-slate-800/50 rounded-2xl border border-slate-200 dark:border-slate-700">
          <TableOfContents headings={headings} />
        </div>

        <div class="prose prose-lg prose-slate dark:prose-invert prose-img:rounded-2xl mx-auto md:mx-0">
          <slot />
        </div>
      </article>

      <!-- Kolom Kanan: Sidebar Sticky (Lebar: Tetap, Tersembunyi di Mobile) -->
      <aside class="hidden lg:block w-72 shrink-0">
        <!-- Posisi Sticky agar mengikuti scroll -->
        <div class="sticky top-28 space-y-10">
          <TableOfContents headings={headings} />
          
          <div class="border-t border-slate-200 dark:border-slate-800 pt-8">
            <ShareButtons title={frontmatter.title} url={currentUrl} />
          </div>
        </div>
      </aside>

      <!-- Share Button untuk Mobile (Muncul di bawah artikel pada layar kecil) -->
      <div class="block lg:hidden border-t border-slate-200 dark:border-slate-800 pt-8">
        <ShareButtons title={frontmatter.title} url={currentUrl} />
      </div>

    </div>

  </div>
</BaseLayout>
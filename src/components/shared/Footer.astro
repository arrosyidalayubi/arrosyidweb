---
// src/components/shared/Footer.astro
const currentYear = new Date().getFullYear();
import { Image } from 'astro:assets';
---

<footer class="bg-white dark:bg-slate-900 border-t border-slate-200 dark:border-slate-800 mt-auto">
  <div class="max-w-7xl mx-auto px-4 md:px-8 py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12">
      
      <!-- Kolom 1: Brand & Bio (Lebih lebar) -->
      <div class="md:col-span-5 lg:col-span-6">
        <a href="/" class="text-2xl font-extrabold text-slate-900 dark:text-white tracking-tighter mb-4 inline-block focus:outline-none focus:ring-2 focus:ring-blue-500 rounded-lg">
          <Image 
              src= "/Logo.svg"
              alt="Logo Arrosyid Al Ayubi"
              class="inline mr-2 -mt-1" 
              width={100}
              height={100}
              aria-label="logo"
              loading="lazy"
            />
        </a>
        <p class="text-slate-600 dark:text-slate-400 text-sm md:text-base leading-relaxed mb-6 max-w-md">
          Pengembang Web & Mobile yang berfokus pada pembuatan antarmuka modern, performa tinggi, dan pengalaman pengguna yang luar biasa.
        </p>
        
        <!-- Ikon Media Sosial -->
        <div class="flex items-center gap-4">
          <!-- Github -->
          <a href="https://github.com/arrosyidalayubi" target="_blank" rel="noopener noreferrer" class="p-2 -ml-2 text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 rounded-lg" aria-label="Profil GitHub">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" /></svg>
          </a>
          <!-- LinkedIn -->
          <a href="https://linkedin.com/in/arrosyid-al-ayubi-b02521141" target="_blank" rel="noopener noreferrer" class="p-2 text-slate-400 hover:text-blue-600 transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 rounded-lg" aria-label="Profil LinkedIn">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd" /></svg>
          </a>
          <!-- Email -->
          <a href="mailto:mail@arrosyid.my.id" class="p-2 text-slate-400 hover:text-red-500 transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 rounded-lg" aria-label="Kirim Email">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
          </a>
        </div>
      </div>

      <!-- Kolom 2: Tautan Cepat -->
      <div class="md:col-span-3 lg:col-span-3">
        <h3 class="text-slate-900 dark:text-white font-bold mb-4 uppercase tracking-wider text-sm">Navigasi</h3>
        <ul class="space-y-3 text-sm font-medium text-slate-600 dark:text-slate-400">
          <li><a href="/" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors focus:outline-none focus:text-blue-600">Beranda</a></li>
          <li><a href="/proyek" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors focus:outline-none focus:text-blue-600">Studi Kasus Proyek</a></li>
          <li><a href="/blog" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors focus:outline-none focus:text-blue-600">Artikel & Catatan</a></li>
          <li><a href="/vlog" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors focus:outline-none focus:text-blue-600">Vlog Perjalanan</a></li>
        </ul>
      </div>

      <!-- Kolom 3: Status Pekerjaan -->
      <div class="md:col-span-4 lg:col-span-3">
        <h3 class="text-slate-900 dark:text-white font-bold mb-4 uppercase tracking-wider text-sm">Status</h3>
        <div class="flex items-center gap-3 mb-6 p-4 bg-slate-50 dark:bg-slate-800/50 rounded-xl border border-slate-100 dark:border-slate-800">
          <span class="relative flex h-3 w-3 shrink-0">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-3 w-3 bg-green-500"></span>
          </span>
          <span class="text-sm font-medium text-slate-700 dark:text-slate-300">Tersedia untuk proyek *freelance*</span>
        </div>
        <a href="mailto:mail@arrosyid.my.id" class="inline-flex w-full justify-center items-center px-4 py-2.5 border border-slate-200 dark:border-slate-700 rounded-lg text-sm font-bold text-slate-800 dark:text-white hover:bg-slate-50 dark:hover:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all shadow-sm hover:shadow">
          Mari Berdiskusi
        </a>
      </div>

    </div>

    <!-- Garis Bawah & Hak Cipta -->
    <div class="mt-12 pt-8 border-t border-slate-200 dark:border-slate-800 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-sm text-slate-500 dark:text-slate-400 font-medium">
        &copy; {currentYear} Arrosyid Al Ayubi. Hak Cipta Dilindungi.
      </p>
      <p class="text-sm text-slate-500 dark:text-slate-400 flex items-center gap-1.5">
        Dibuat dengan <svg class="w-4 h-4 text-red-500 animate-pulse" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd" /></svg> menggunakan Astro
      </p>
    </div>
  </div>
</footer>
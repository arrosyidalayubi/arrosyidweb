---
// src/components/home/LatestBlogs.astro
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const allPosts = await getCollection('blog');
const latestPosts = allPosts
  .sort((a, b) => new Date(b.data.publishDate).valueOf() - new Date(a.data.publishDate).valueOf())
  .slice(0, 3);
---

<section id="tulisan-terbaru" class="mb-24">
  <div class="flex items-center justify-between mb-8 border-b border-slate-200 dark:border-slate-800 pb-4">
    <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Tulisan Terbaru</h2>
    <a href="/blog" class="text-blue-600 dark:text-blue-400 font-semibold hover:underline">Lihat Semua →</a>
  </div>

  <div class="grid md:grid-cols-3 gap-6 md:gap-8">
    {latestPosts.map((post) => (
      <article class="bg-white dark:bg-slate-900 rounded-2xl shadow-sm border border-slate-200 dark:border-slate-800 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group flex flex-col overflow-hidden">
        
        <!-- Wadah Gambar (Sama persis dengan desain object-contain) -->
        <a href={`/blog/${post.id}`} class="block relative w-full h-48 bg-slate-50 dark:bg-slate-800 shrink-0 border-b border-slate-100 dark:border-slate-700">
          {post.data.coverImage ? (
            <Image 
              src={post.data.coverImage} 
              alt={post.data.title} 
              class="w-full h-full object-contain rounded-t-2xl p-4 group-hover:scale-105 transition-transform duration-500"
              width={600} height={300}
            />
          ) : (
            <div class="absolute inset-0 flex items-center justify-center text-slate-300 dark:text-slate-600">
              <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
            </div>
          )}
        </a>

        <!-- Wadah Teks -->
        <div class="p-6 flex flex-col flex-1 justify-between">
          <div>
            <a href={`/blog/${post.id}`} class="block">
              <h3 class="text-xl font-bold text-slate-800 dark:text-slate-100 mb-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors line-clamp-2 leading-tight">
                {post.data.title}
              </h3>
              <p class="text-slate-600 dark:text-slate-400 text-sm mb-4 line-clamp-2">
                {post.data.description}
              </p>
            </a>
          </div>
          
          <div class="mt-auto pt-4 border-t border-slate-100 dark:border-slate-800 flex flex-wrap items-center justify-between gap-3">
            <time class="text-xs font-semibold text-slate-500 dark:text-slate-400">
              {new Date(post.data.publishDate).toLocaleDateString('id-ID', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
          </div>
        </div>
        
      </article>
    ))}
  </div>
</section>
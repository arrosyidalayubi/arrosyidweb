---
// src/components/home/FeaturedProjects.astro
import { getCollection } from 'astro:content';
// Wajib import komponen Image
import { Image } from 'astro:assets';

const allProjects = await getCollection('proyek');
const featuredProjects = allProjects
  .sort((a, b) => new Date(b.data.publishDate).valueOf() - new Date(a.data.publishDate).valueOf())
  .slice(0, 4);
---

<section id="proyek" class="mb-24">
  <div class="flex items-center justify-between mb-8 border-b border-slate-200 dark:border-slate-800 pb-4">
    <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Proyek Pilihan</h2>
    <a href="/proyek" class="text-blue-600 dark:text-blue-400 font-semibold hover:underline">Lihat Semua →</a>
  </div>
  
  <div class="grid md:grid-cols-2 gap-8">
    {featuredProjects.map(project => (
      <article class="group bg-white dark:bg-slate-900 rounded-3xl border border-slate-200 dark:border-slate-800 overflow-hidden hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 flex flex-col">
        
        <!-- Wadah Gambar (Tinggi Tetap, Object Cover) -->
        <a href={`/proyek/${project.id}`} class="block relative w-full h-56 bg-slate-100 dark:bg-slate-800 shrink-0 border-b border-slate-200 dark:border-slate-800 overflow-hidden">
          {project.data.coverImage ? (
            <Image 
              src={project.data.coverImage} 
              alt={`Cover ${project.data.title}`} 
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              width={800} height={400}
            />
          ) : (
            <div class="absolute inset-0 flex items-center justify-center text-slate-400 dark:text-slate-500 font-medium">
              Preview {project.data.title}
            </div>
          )}
        </a>

        <!-- Wadah Teks (Padding p-8 diletakkan di sini) -->
        <div class="p-8 flex flex-col flex-1 justify-between">
          <div>
            <div class="flex flex-wrap gap-2 mb-4">
              {project.data.techStack.slice(0, 3).map((tech: string) => (
                <span class="px-3 py-1 bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400 text-xs font-bold rounded-full">{tech}</span>
              ))}
            </div>
            <a href={`/proyek/${project.id}`} class="block">
              <h3 class="text-2xl font-bold text-slate-900 dark:text-white mb-3 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">{project.data.title}</h3>
              <p class="text-slate-600 dark:text-slate-400 mb-6 line-clamp-3">{project.data.description}</p>
            </a>
          </div>
          
          <div class="mt-auto">
            <a href={`/proyek/${project.id}`} class="inline-flex items-center text-blue-600 dark:text-blue-400 font-semibold group-hover:text-blue-700 dark:group-hover:text-blue-300">
              Lihat Studi Kasus <span class="ml-2 group-hover:translate-x-1 transition-transform">→</span>
            </a>
          </div>
        </div>

      </article>
    ))}
  </div>
</section>
---
// src/components/media/MosaicGallery.astro
import { Image } from 'astro:assets';

interface Props {
  images: ImageMetadata[];
}

const { images } = Astro.props;
---

<!-- Menambahkan class 'breakout' jika ingin galeri ini full-width -->
<div class="grid grid-cols-2 md:grid-cols-4 gap-2 md:gap-4 my-8 breakout px-4 md:px-0 max-w-7xl mx-auto">
  {images.map((img, index) => (
    <div class={`overflow-hidden rounded-xl shadow-sm hover:shadow-md transition-shadow ${index === 0 || index === 3 ? 'col-span-2 md:col-span-2 row-span-2' : 'col-span-1'}`}>
      <Image 
        src={img} 
        alt={`Gallery image ${index + 1}`} 
        class="w-full h-full object-cover transition-transform duration-500 hover:scale-105"
        widths={[400, 800]}
        sizes="(max-width: 768px) 100vw, 50vw"
      />
    </div>
  ))}
</div>
---
// src/components/blog/TableOfContents.astro
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
// Hanya ambil heading H2 dan H3 agar daftar isi tidak terlalu panjang/dalam
const filteredHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{filteredHeadings.length > 0 && (
  <nav class="toc-container">
    <h4 class="text-sm font-bold text-slate-900 dark:text-white uppercase tracking-wider mb-4">Daftar Isi</h4>
    <ul class="space-y-2.5 text-sm">
      {filteredHeadings.map((heading) => (
        <li class={heading.depth === 3 ? "ml-4" : ""}>
          <a 
            href={`#${heading.slug}`} 
            class="toc-link block text-slate-600 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors line-clamp-2"
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

<script>
  // Logika Observer untuk menyorot daftar isi yang sedang aktif
  document.addEventListener('astro:page-load', () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        const id = entry.target.getAttribute('id');
        const tocLink = document.querySelector(`.toc-link[href="#${id}"]`);
        
        if (entry.isIntersecting && tocLink) {
          // Hapus status aktif dari semua link
          document.querySelectorAll('.toc-link').forEach((link) => {
            link.classList.remove('text-blue-600', 'dark:text-blue-400', 'font-semibold');
          });
          // Tambahkan status aktif ke link yang sedang dilihat
          tocLink.classList.add('text-blue-600', 'dark:text-blue-400', 'font-semibold');
        }
      });
    }, { rootMargin: '-100px 0px -66% 0px' }); // Pemicu saat heading mencapai 100px dari atas layar

    // Observasi semua heading H2 dan H3 di dalam artikel
    document.querySelectorAll('.prose h2, .prose h3').forEach((heading) => {
      observer.observe(heading);
    });
  });
</script>